# Anthropic (Claude) — required for nudges, question extraction, PDF body, cover messages
ANTHROPIC_API_KEY=
# Optional override if your key does not have access to the default model
# Example: claude-sonnet-4-6
ANTHROPIC_MODEL=

# OpenAI — required for Whisper transcription
OPENAI_API_KEY=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox example: whatsapp:+14155238886 — must match your WhatsApp sender
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: default lead number for Post-Call presets / demos (E.164). Overrides preset placeholders.
# DEMO_LEAD_WHATSAPP=+9198...

# Required for WhatsApp PDF attachments: public HTTPS URL base where Twilio can GET the file.
# The app writes PDFs to ./static/ — this URL must resolve those filenames (e.g. .../static/scaler-brief-abc.pdf).
# Local dev: serve ./static over HTTPS (e.g. ngrok) then set:
# STATIC_PUBLIC_BASE_URL=https://xxxx.ngrok-free.app/static
STATIC_PUBLIC_BASE_URL=

# Option B — writable folder + base URL (legacy)
# TWILIO_PUBLIC_MEDIA_PATH=C:/path/to/public/pdfs
# TWILIO_PUBLIC_MEDIA_URL=https://your-domain.example/pdfs
